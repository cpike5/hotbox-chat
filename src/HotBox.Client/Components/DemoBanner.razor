@inject AuthState AuthState
@inject ApiClient ApiClient
@implements IDisposable

@if (AuthState.IsDemo)
{
    <div class="demo-banner" role="status">
        <div class="demo-banner-content">
            <svg class="demo-banner-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="12" y1="8" x2="12" y2="12"></line>
                <line x1="12" y1="16" x2="12.01" y2="16"></line>
            </svg>
            <span>Demo Mode — Your data will be deleted after @_timeoutMinutes minutes of inactivity</span>
        </div>
    </div>
}

@code {
    private int _timeoutMinutes = 5;

    protected override async Task OnInitializedAsync()
    {
        AuthState.OnChange += StateHasChanged;

        var status = await ApiClient.GetDemoStatusAsync();
        if (status is not null && status.SessionTimeoutMinutes > 0)
        {
            _timeoutMinutes = status.SessionTimeoutMinutes;
        }
    }

    public void Dispose()
    {
        AuthState.OnChange -= StateHasChanged;
    }
}
