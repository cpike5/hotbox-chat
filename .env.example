# HotBox v2 Docker Compose Environment Variables
# Copy this file to .env and update the values before running docker compose up.

# Database password for PostgreSQL
DB_PASSWORD=changeme

# JWT signing secret (MUST be at least 32 characters)
JWT_SECRET=super-secret-key-change-in-production-minimum-32-chars

# Admin seed account (created on first startup)
ADMIN_EMAIL=admin@hotbox.local
ADMIN_PASSWORD=Admin123!
ADMIN_DISPLAY_NAME=Admin

# Port mappings (optional)
HOTBOX_PORT=7200
SEQ_PORT=7201

# Observability (optional)
APM_OTLP_ENDPOINT=
APM_API_KEY=
ELASTICSEARCH_URL=
ELASTICSEARCH_API_KEY=
